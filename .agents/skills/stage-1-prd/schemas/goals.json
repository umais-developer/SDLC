{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stage 1 Goals & Requirements",
  "type": "object",
  "required": ["problem_id", "goals", "functional_requirements", "non_functional_requirements", "constraints", "out_of_scope", "testing_strategy", "dependencies"],
  "properties": {
    "problem_id": {
      "type": "string",
      "minLength": 1
    },
    "goals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "success_criteria", "priority"],
        "properties": {
          "id": { "type": "string", "pattern": "^GOAL-\\d+$" },
          "description": { "type": "string", "minLength": 1 },
          "success_criteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2"] }
        },
        "additionalProperties": false
      }
    },
    "functional_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "acceptance_criteria", "priority", "links_to"],
        "properties": {
          "id": { "type": "string", "pattern": "^FR-\\d+$" },
          "description": { "type": "string", "minLength": 1 },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "links_to": { "type": "array", "items": { "type": "string" } },
          "story_points": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "non_functional_requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "acceptance_criteria", "priority"],
        "properties": {
          "id": { "type": "string", "pattern": "^NFR-\\d+$" },
          "description": { "type": "string", "minLength": 1 },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "story_points": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "rationale"],
        "properties": {
          "id": { "type": "string", "pattern": "^CON-\\d+$" },
          "description": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "testing_strategy": {
      "type": "object",
      "properties": {
        "unit_tests": { "type": "array", "items": { "type": "string" } },
        "integration_tests": { "type": "array", "items": { "type": "string" } },
        "browser_tests": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "must_complete_first": { "type": "array", "items": { "type": "string" } },
        "blocks": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
