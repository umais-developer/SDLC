{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stage 1 Problem Statement",
  "type": "object",
  "required": [
    "raw_request",
    "request_type",
    "size",
    "primary_goal",
    "user_pain_point",
    "scope_boundaries",
    "affected_areas",
    "dependencies",
    "ambiguities",
    "contradictions",
    "traceability"
  ],
  "properties": {
    "raw_request": {
      "type": "string",
      "minLength": 1
    },
    "request_type": {
      "type": "string",
      "enum": ["feature", "bug_fix", "refactor", "other"]
    },
    "size": {
      "type": "string",
      "enum": ["trivial", "medium", "large"],
      "description": "Request scope: trivial = single isolated change touching ≤2 files; medium = self-contained feature, 1-3 components; large = cross-cutting, new subsystem, or greenfield. Set during Stage 1 problem interpretation; downstream stages inherit this without re-deriving."
    },
    "primary_goal": {
      "type": "string",
      "minLength": 10
    },
    "user_pain_point": {
      "type": ["string", "null"]
    },
    "scope_boundaries": {
      "type": "object",
      "required": ["in_scope", "out_of_scope", "ambiguous"],
      "properties": {
        "in_scope": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "out_of_scope": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ambiguous": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "affected_areas": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "dependencies": {
      "type": "object",
      "required": ["must_complete_first", "may_enable"],
      "properties": {
        "must_complete_first": { "type": "array", "items": { "type": "string" } },
        "may_enable": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "ambiguities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "contradictions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "traceability": {
      "type": "object",
      "required": ["links_to_requirements", "addresses_expected_outcome"],
      "properties": {
        "links_to_requirements": {
          "type": "array",
          "items": { "type": "string" }
        },
        "addresses_expected_outcome": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
