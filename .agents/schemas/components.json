{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ComponentsSchema",
  "type": "object",
  "required": ["components", "data_flow", "dependency_graph", "entry_point", "file_structure"],
  "properties": {
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "fr_links", "justification"],
        "properties": {
          "name":             { "type": "string" },
          "file":             { "type": "string" },
          "modified":         { "type": "boolean" },
          "changes":          { "type": "array", "items": { "type": "string" } },
          "responsibility":   { "type": "string" },
          "public_interface": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "state_owned":      { "type": "array", "items": { "type": "string" } },
          "depends_on":       { "type": "array", "items": { "type": "string" } },
          "fr_links":         { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "justification":    { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "data_flow": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dependency_graph": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "entry_point": { "type": "string" },
    "file_structure": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pre_existing_components": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Names of components that already exist in the codebase and are depended on but not redefined here"
    }
  },
  "additionalProperties": true
}
